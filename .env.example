# Trader-VIX — Environment Variables
# Copy to .env for local dev. Set in Railway dashboard for production.
# NEVER commit .env to git.

# ── Tastytrade ────────────────────────────────────────────────────────────────
TASTYTRADE_USERNAME=your_tastytrade_username
TASTYTRADE_PASSWORD=your_tastytrade_password
TASTYTRADE_ACCOUNT_NUM=your_account_number
TASTYTRADE_PAPER=true

# ── OANDA (forex carry — add after Tastytrade is live) ────────────────────────
OANDA_API_KEY=your_oanda_api_token
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_PAPER=true
CARRY_ENABLED=false

# ── Capital ───────────────────────────────────────────────────────────────────
TOTAL_CAPITAL=20000
SWING_CAPITAL_PCT=0.60
ZEDTE_CAPITAL_PCT=0.20
CARRY_CAPITAL_PCT=0.20

# ── Strategy toggles ──────────────────────────────────────────────────────────
SWING_ENABLED=true
ZEDTE_ENABLED=true
CARRY_ENABLED=false

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=change_this_password
SECRET_KEY=change_this_secret_key
PORT=3005

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFY_EMAIL=everett@tryrebuilt.com
FROM_EMAIL=emmett@getrebuilt.app

# ── Risk (defaults are safe — only override if you know why) ──────────────────
# MAX_PORTFOLIO_DRAWDOWN=0.15
# DAILY_LOSS_LIMIT=0.05
# SWING_MAX_SPREADS=4
# ZEDTE_MAX_CONDORS=4
# CARRY_MAX_POSITIONS=2
# CARRY_STOP_PCT=0.10
# CARRY_LEVERAGE=3.0

LOG_LEVEL=INFO
