# Trader-VIX — Environment Variables
# Copy to .env for local dev. Set in Railway dashboard for production.
# NEVER commit .env to git.

# ── Tastytrade ────────────────────────────────────────────────────────────────
TASTYTRADE_USERNAME=your@email.com
TASTYTRADE_PASSWORD=your_tastytrade_password
TASTYTRADE_ACCOUNT_NUM=5WI57245

# TASTYTRADE_PAPER=true uses the cert sandbox (separate account required)
# TASTYTRADE_PAPER=false uses your real account (5WI57245)
# Leave as false — DRY_RUN=true handles simulation without a sandbox account
TASTYTRADE_PAPER=false

# DRY_RUN=true: authenticates with production, pulls real market data,
# but intercepts ALL order calls — nothing is actually traded.
# This is the recommended paper trading mode when using your live IRA account.
# Set to false only when ready to execute real trades with real money.
# Requires: 60+ days of DRY_RUN results + explicit go-live decision logged in Notion.
DRY_RUN=true

# ── Capital ───────────────────────────────────────────────────────────────────
TOTAL_CAPITAL=20000
SWING_CAPITAL_PCT=0.60
ZEDTE_CAPITAL_PCT=0.20
CARRY_CAPITAL_PCT=0.20

# ── Strategy toggles ──────────────────────────────────────────────────────────
SWING_ENABLED=true
ZEDTE_ENABLED=true
CARRY_ENABLED=false

# ── OANDA (forex carry — add later) ───────────────────────────────────────
# OANDA_API_KEY=your_oanda_api_token
# OANDA_ACCOUNT_ID=your_oanda_account_id
# OANDA_PAPER=true

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=change_this_password
SECRET_KEY=change_this_to_a_long_random_string
PORT=3005

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFY_EMAIL=everett@tryrebuilt.com
FROM_EMAIL=emmett@getrebuilt.app

# ── Risk (safe defaults — only override if intentional) ──────────────────────
# MAX_PORTFOLIO_DRAWDOWN=0.15
# DAILY_LOSS_LIMIT=0.05
# SWING_MAX_SPREADS=4
# ZEDTE_MAX_CONDORS=4

LOG_LEVEL=INFO
